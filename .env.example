# ── Meta / Facebook ───────────────────────────────────────────────────────────
# Your Facebook App Secret (from Meta Developer App settings — NOT page access token)
APP_SECRET=your_facebook_app_secret_here
# Verification token — make up your own random string, used when registering webhook
VERIFY_TOKEN=your_own_random_verify_token

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Twilio (SMS — NOT WhatsApp) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+353xxxxxxxxx

# ── Resend (email backup) ─────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=leads@usetradebot.app

# ── App Config ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
DASHBOARD_URL=https://dashboard.usetradebot.app

# ── Test / Demo ───────────────────────────────────────────────────────────────
# TEST_MODE=true sends all SMS to TEST_PHONE only — safe for demos
TEST_MODE=true
TEST_PHONE=+353871234567
